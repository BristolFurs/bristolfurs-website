<div class="bf-splash">
  {% image "homepage.jpg", "A collage of six fursuiters. A blue, black and white cat peeks from behind a wall. A cheetah with purple eye shadow and glasses motions upwards. Two white and brown canids with medium length black hair hug. A goat with green eyes and brown horns stares into the camera. A black, robotic bird with yellow markings looks onwards.", "Kirin Eldridge", { class: "bf-splash__media", loading: "eager", widths: [320, 550, 768, 1000, 1240, 1640] } %}
  
  <div class="bf-container bf-splash__container">
    <div class="bf-splash__card">
      <h2 class="bf-heading-2xl bf-!-margin-block-start-0 bf-!-margin-block-end-m">
        <div class="bf-body-l bf-!-margin-block-end-3xs">Next furmeet</div>
        {{ meetInfo.nextMeetDate | formatDate('EEEE, do MMMM yyyy') }}
      </h2>
      <p class="bf-body-s">Our main event, a whole day of fun and games with furries and fursuits galore!</p>
      {%- if meetInfo.schedule %}
        <dl class="bf-schedule">
          {%- for row in meetInfo.schedule %}
            <dt class="bf-schedule__time">
              {{ row.startTime }}
            </dt>
            <dd class="bf-schedule__content">
              {{ row.title }}
              {%- if row.subtitle %}
              <div class="bf-small-print">{{ row.subtitle }}</div>
              {%- endif %}
            </dd>
          {%- endfor %}
        </dl>
      {%- endif %}
      <a class="bf-button bf-button--full-width" href="{{ '/attending-a-meet/' | url }}">
        Furmeet guide
      </a>
    </div>
    
    <div class="bf-splash__card">
      <h2 class="bf-heading-2xl bf-!-margin-block-start-0 bf-!-margin-block-end-m">
        <div class="bf-body-l bf-!-margin-block-end-3xs">Next tabletop meet</div>
        {%- if miniMeetInfo.nextMeetDate %}
          {{ miniMeetInfo.nextMeetDate | formatDate('EEEE, do MMMM yyyy')}}
        {%- else %}
          Not scheduled yet
        {%- endif %}
      </h2>
      <p class="bf-body-s">Tabletop meets are smaller events centred around all things tabletop gaming.</p>
      {%- if miniMeetInfo.nextMeetDate and miniMeetInfo.schedule %}
        <dl class="bf-schedule">
          {%- for row in miniMeetInfo.schedule %}
            <dt class="bf-schedule__time">
              {{ row.startTime }}
            </dt>
            <dd class="bf-schedule__content">
              {{ row.title }}
              {%- if row.subtitle %}
              <div class="bf-small-print">{{ row.subtitle }}</div>
              {%- endif %}
            </dd>
          {%- endfor %}
        </dl>
      {%- else %}
        <p class="bf-body">Check back soon for information on when the next mini-meet will be!</p>
      {%- endif %}
      <a class="bf-button bf-button--full-width" href="{{ '/attending-a-meet/tabletop-meets/' | url }}">
        About tabletop meets
      </a>
    </div>
  </div>
</div>
